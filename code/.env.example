# ────── Base de données (Neon PostgreSQL) ──────
# Obtenez votre URL depuis https://console.neon.tech/
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ────── Cloudinary (Upload d'images) ──────
# Obtenez vos identifiants depuis https://console.cloudinary.com/
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="votre_cloud_name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="votre_upload_preset"

# ────── API URL ──────
# En développement local, utilisez /api
# En production Vercel, utilisez /api aussi (relatif)
NEXT_PUBLIC_API_URL="/api"

# ────── Capacitor (Développement mobile) ──────
# URL du serveur Next.js pour le développement avec Android Studio
# Pour émulateur Android : http://10.0.2.2:3000
# Pour appareil physique sur même réseau : http://VOTRE_IP_LOCALE:3000
CAPACITOR_SERVER_URL="http://10.0.2.2:3000"
